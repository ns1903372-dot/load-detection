          <mxGeometry x="870" y="160" width="240" height="120" as="geometry" />
        </mxCell>

        <mxCell id="feature" value="5. Feature Extraction&#xa;- DWT decomposition&#xa;- Approximation and detail coefficients&#xa;- Statistical + Hjorth features" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1150" y="160" width="260" height="120" as="geometry" />
        </mxCell>

        <mxCell id="dataset" value="6. Dataset Preparation&#xa;- Merge subject features&#xa;- Build labeled dataset&#xa;- Train / test split&#xa;- Binary class selection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;spacingLeft=8;" vertex="1" parent="1">
