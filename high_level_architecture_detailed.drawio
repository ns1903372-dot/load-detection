        <mxCell id="input" value="1. Data Acquisition&#xa;- EEG raw recordings&#xa;- EDF / MAT / CSV files&#xa;- Subject/session-wise input" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="220" height="120" as="geometry" />
        </mxCell>

