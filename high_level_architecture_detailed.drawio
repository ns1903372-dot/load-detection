          <mxGeometry x="300" y="160" width="240" height="120" as="geometry" />
        </mxCell>

        <mxCell id="preprocess" value="3. Signal Preprocessing&#xa;- Band-pass filtering&#xa;- ICA artifact removal&#xa;- Noise reduction / normalization" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="580" y="160" width="250" height="120" as="geometry" />
        </mxCell>

